# ============================================================
# MusicAgent .gitignore
# ============================================================

# ------------------------------------------------------------
# .NET / WinForms
# ------------------------------------------------------------
bin/
obj/
**/bin/
**/obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.pidb
*.booproj

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet
**/packages/*
*.nupkg
**/[Pp]ackages/**
*.nuget.props
*.nuget.targets

# ------------------------------------------------------------
# Node.js / Frontend
# ------------------------------------------------------------
node_modules/
**/node_modules/

# npm / pnpm / yarn
package-lock.json
pnpm-lock.yaml
yarn.lock
.npm
.pnpm-store/

# Vite / React build output
dist/
**/dist/
build/
**/build/
.tmp-build/
**/.tmp-build/
.vite/
**/.vite/

# TypeScript build output (aaudiocore)
react/aaudiocore/dist/

# ------------------------------------------------------------
# WinForms WebView2 runtime data
# ------------------------------------------------------------
*.WebView2/
**/*.WebView2/
EBWebView/
**/EBWebView/

# ------------------------------------------------------------
# Runtime-generated local data
# ------------------------------------------------------------
musicagent.db
musicagent.db-*
musicagent.db-shm
musicagent.db-wal
localpaths.json

# NeteaseCloudMusicApi cache
netease-cache/
**/netease-cache/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------
# Environment / Secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------
# Visual Studio
.vs/

# JetBrains Rider / IntelliJ
.idea/
*.rsuser
_ReSharper*/
*.DotSettings.user

# VS Code
.vscode/

# ------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Test / Coverage
# ------------------------------------------------------------
coverage/
**/coverage/
.nyc_output/

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.swp
*.swo
*~
*.bak
*.tmp
*.temp
